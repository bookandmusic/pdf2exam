# ============================================
# API 配置
# ============================================
API_KEY=""  # OpenAI API 密钥（必填）
API_URL="https://api.openai.com/v1"  # API 端点地址
MODEL_NAME="gpt-4o"  # 使用的模型名称

# ============================================
# 模型参数
# ============================================
TEMPERATURE=0.0  # 温度参数，控制输出随机性 (0.0-2.0)
SEED=42  # 随机种子，用于结果可复现
ENABLE_THINKING=true  # 是否启用模型思考过程输出
MAX_OUTPUT_TOKENS=8192  # 最大输出 token 数

# ============================================
# 请求配置
# ============================================
RESPONSE_FORMAT="auto"  # 响应格式：text/none（不使用JSON）、json_object、json_schema、auto（默认json_object）
REQUEST_TIMEOUT=180.0  # 单次请求超时时间（秒）
API_CALL_INTERVAL=3.0  # API调用间隔时间（秒），每次调用前等待的时间

# ============================================
# 上下文配置
# ============================================
CONTEXT_PAGES_BEFORE=1  # 前面附带的上下文页数
CONTEXT_PAGES_AFTER=0  # 后面附带的上下文页数

# ============================================
# 图片处理配置
# ============================================
IMAGE_MAX_SIZE=2048  # 图片最大边长限制（像素），超过会自动缩放 (512-4096)
IMAGE_JPEG_QUALITY=85  # JPEG 压缩质量 (50-100)，推荐 85-95

# ============================================
# 调试配置
# ============================================
DEBUG_LOG_THINKING=false  # 是否在控制台实时输出模型思考过程

# ============================================
# 产物配置
# ============================================
ARTIFACT_DIR=""  # 产物根目录路径
ARTIFACT_NAME=""  # 产物名称（用作子目录名和文件名）

# ============================================
# 默认运行参数（可通过 CLI 参数覆盖）
# ============================================

# --- 运行模式 ---
TEST_IMAGE=""  # 测试模式：指定单张图片进行测试
INPUT_DIR=""  # 目录模式：批量处理整个图片目录

# --- 批处理配置（目录模式） ---
STEP=  # 每批主处理的页数
START_FROM=  # 从文件名数字序号大于等于该值的图片开始处理
END_AT=  # 处理到文件名数字序号小于等于该值的图片结束

# --- 题目元数据 ---
DEFAULT_TOPIC=""  # 默认专题名称（从中间继续解析时使用）
DEFAULT_CHAPTER=""  # 默认章名称（从中间继续解析时使用）
DEFAULT_SECTION=""  # 默认节名称（从中间继续解析时使用）
SUBJECT_ID=""  # 输出题库 ID
SUBJECT_NAME=""  # 输出题库名称

# --- 质量控制 ---
CONSENSUS=true  # 是否启用共识机制（2次提取+AI裁决，提高准确性但增加成本）
